{
  "description": "Cross-CLI lifecycle hooks. Uses only the 8 events common to Claude Code (28), Codex CLI (9), Copilot CLI (8), and Kimi (16). All four CLIs support these 8 events. JSON format works for Claude/Codex/Copilot; Kimi uses the TOML equivalent in kimi-hooks.toml.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/session-start.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/user-prompt-submit.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/pre-tool-use.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/post-tool-use.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/pre-compact.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/subagent-start.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/subagent-stop.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$HOME/.dotfiles/config/agents}/hooks/stop.mjs\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
