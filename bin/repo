#!/usr/bin/env bash
# Generated by Purpose Tool from .purpose/commands.json. Do not edit.
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
show_help() {
  cat <<'PURPOSE_REPO_HELP'
Usage: repo <command> [args...]

Commands:
  repo check                Run the dotfiles repository verification gate
  repo sync mise-upgrade    Install and upgrade mise-managed tools
  repo vcs describe         Commit the current workspace changes
  repo vcs diff             Show repository changes
  repo vcs fetch            Fetch the Forgejo integration remote
  repo vcs land             Verify and publish a clean task workspace as main
  repo vcs log              Show revision history
  repo vcs push             Verify and publish local main to both remotes
  repo vcs push-github      Verify and publish local main to GitHub only
  repo vcs show             Show one revision
  repo vcs status           Show repository status
  repo vcs test             Verify the repository VCS facade contract
  repo vcs worktree-create  Create an isolated task worktree
  repo vcs worktree-drop    Remove an integrated clean task worktree
  repo vcs worktree-list    List registered worktrees
PURPOSE_REPO_HELP
}
if [[ ${#} -eq 0 || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
  show_help
  exit 0
fi
if [[ "${1:-}" == 'sync' ]] && [[ "${2:-}" == 'mise-upgrade' ]]; then shift 2; exec "$ROOT/scripts/repo-maintenance.sh" 'mise-upgrade' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'describe' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'describe' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'diff' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'diff' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'fetch' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'fetch' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'land' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'land' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'log' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'log' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'push' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'push' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'push-github' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'push-github' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'show' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'show' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'status' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'status' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'test' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'contract-test' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'worktree-create' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'worktree-create' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'worktree-drop' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'worktree-drop' "$@"
elif [[ "${1:-}" == 'vcs' ]] && [[ "${2:-}" == 'worktree-list' ]]; then shift 2; exec "$ROOT/scripts/repo-vcs.sh" 'worktree-list' "$@"
elif [[ "${1:-}" == 'check' ]]; then shift 1; exec "$ROOT/scripts/repo-check.sh" "$@"
else
  echo "unknown command: $*" >&2
  show_help >&2
  exit 2
fi
