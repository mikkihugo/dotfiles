prefix_rule(pattern=["direnv", "allow"], decision="allow")

# Production actions stay operator-controlled.
prefix_rule(pattern=["make", "deploy-prod"], decision="forbidden", justification="Use MCP deploy_to_production.")
prefix_rule(pattern=["make", "deploy-remote-change-watcher"], decision="forbidden", justification="Do not deploy the watcher from agent sessions.")

# Destructive local changes need an explicit safer path.
prefix_rule(pattern=["git", "reset", "--hard"], decision="forbidden", justification="Do not discard work with git reset --hard.")
prefix_rule(pattern=["git", "checkout", "--"], decision="forbidden", justification="Do not discard work with git checkout --.")
prefix_rule(pattern=["jj", "abandon"], decision="prompt", justification="Abandoning revisions discards work; confirm intent first.")
prefix_rule(pattern=["rm", "-rf"], decision="prompt", justification="Recursive delete requires explicit confirmation.")

# Remote shell is allowed; secret decryption prompts.
prefix_rule(pattern=["ssh"], decision="allow")
prefix_rule(pattern=["sops"], decision="prompt", justification="Secrets access requires explicit approval.")
