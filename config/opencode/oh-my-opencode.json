{
  "agents": {
    "prometheus": {
      "enabled": true,
      "replace_plan": true,
      "model": "openai/gpt-5.3-codex"
    },
    "metis": {
      "enabled": true,
      "model": "openai/gpt-5.3-codex"
    },
    "librarian": {
      "enabled": true
    },
    "explore": {
      "enabled": true
    },
    "oracle": {
      "enabled": true,
      "model": "openai/gpt-5.2"
    },
    "sisyphus": {
      "enabled": true,
      "model": "kimi-for-coding/k2p5"
    },
    "sisyphus-junior": {
      "enabled": true,
      "model": "kimi-for-coding/k2p5"
    },
    "atlas": {
      "enabled": true,
      "model": "openai/gpt-5.3-codex-spark"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "enabled": true
    }
  },
  "disabled_hooks": [
    "comment-checker",
    "agent-usage-reminder"
  ],
  "disabled_mcps": [],
  "models": {
    "oracle": "openai/gpt-5.2",
    "orchestrator": "ollama-cloud/minimax-m2.5",
    "fixer": "ollama-cloud/minimax-m2.5",
    "designer": "ollama-cloud/glm-5",
    "librarian": "ollama-cloud/glm-5",
    "explorer": "ollama-cloud/kimi-k2.5",
    "prometheus": "openai/gpt-5.3-codex",
    "metis": "openai/gpt-5.3-codex",
    "sisyphus": "kimi-for-coding/k2p5",
    "sisyphus-junior": "kimi-for-coding/k2p5",
    "atlas": "openai/gpt-5.3-codex-spark",
    "hephaestus": "openai/gpt-5.3-codex"
  },
  "lsp": {
    "pylsp": {
      "command": [
        "pylsp"
      ],
      "extensions": [
        ".py"
      ],
      "priority": 10
    },
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "priority": 9
    }
  },
  "experimental": {
    "preemptive_compaction_threshold": 0.8,
    "truncate_all_tool_outputs": true,
    "aggressive_truncation": false,
    "auto_resume": true,
    "dcp_for_compaction": true
  }
}
