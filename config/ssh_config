# SSH host aliases and the exact key file configured for each block.
# IdentitiesOnly=yes ensures only the listed key is used for authentication.

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ControlMaster auto
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlPersist 10m
    AddKeysToAgent yes

Host ai.hugo.dk vpn.hugo.dk jump.hugo.dk
    User root
    IdentityFile ~/.ssh/personal_admin_id_ed25519
    IdentitiesOnly yes

Host cc-fi-hel-k3s-03 cc-fi-hel-k3s-03.centralcloud.com rigel rigel.hugo.dk flow.hugo.dk portal-workflow
    HostName 157.180.79.108
