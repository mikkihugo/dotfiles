# SSH host aliases and the exact key file configured for each block.
# IdentitiesOnly=yes ensures only the listed key is used for authentication.

Host mail.hugo.dk ai.hugo.dk vpn.hugo.dk
    # Central Hetzner-hosted machines use the Hetzner-specific key.
    User root
    IdentityFile ~/.ssh/hetzner_id_ed25519
    IdentitiesOnly yes

Host flow.hugo.dk portal-workflow
    HostName flow.hugo.dk
    User root
    IdentityFile ~/.ssh/personal_admin_id_ed25519
    IdentitiesOnly yes

# Personal Hetzner/public servers — use the personal admin key here.
Host mon.hugo.dk mon.portal.centralcloud.com mail.sendramp.com
    HostName 77.42.29.242
    User root
    IdentityFile ~/.ssh/personal_admin_id_ed25519
    IdentitiesOnly yes

Host portal-automation
    # Portal automation node on public IP uses the personal admin key.
    HostName 157.180.79.108
    User root
    IdentityFile ~/.ssh/personal_admin_id_ed25519
    IdentitiesOnly yes

