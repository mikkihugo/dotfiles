#!/usr/bin/env bash
# scripts/fetch-kubeconfig — pull the k3s kubeconfig from rigel and rewrite
# it for off-cluster use.
#
# Usage:
#   fetch-kubeconfig                    — write to ~/.kube/config
#   fetch-kubeconfig <path>             — write to <path> instead
#
# What it does:
#   1. SSH to rigel as root, cat /etc/rancher/k3s/k3s.yaml
#   2. Replace the 127.0.0.1 server URL with rigel's public IP
#   3. Set tls-server-name to "rigel" (the only hostname in the cert SANs
#      that matches what we're hitting; the cert was issued before
#      rigel.hugo.dk was a thing)
#   4. chmod 600 the resulting file
#
# Requires:
#   - SSH key authorised to root@rigel (~/.ssh/personal_admin_id_ed25519)
#   - kubectl installed (so the user can actually use the result)

set -euo pipefail

DEST="${1:-$HOME/.kube/config}"
RIGEL_PUBLIC_IP="157.180.79.108"
TLS_SERVER_NAME="rigel"

mkdir -p "$(dirname "$DEST")"

ssh rigel 'cat /etc/rancher/k3s/k3s.yaml' \
	| sed "s|server: https://127.0.0.1:6443|server: https://$RIGEL_PUBLIC_IP:6443|" \
	| python3 -c "
import sys, yaml
cfg = yaml.safe_load(sys.stdin)
for c in cfg.get('clusters', []):
    c['cluster']['tls-server-name'] = '$TLS_SERVER_NAME'
yaml.dump(cfg, sys.stdout, default_flow_style=False)
" \
	> "$DEST"

chmod 600 "$DEST"
echo "wrote $DEST"

# quick sanity check
if command -v kubectl >/dev/null 2>&1; then
	echo
	KUBECONFIG="$DEST" kubectl get nodes --no-headers 2>&1 | head -5
fi
