#!/usr/bin/env bash
# scripts/secrets-edit — fzf picker for SOPS secrets files
#
# Usage:
#   secrets              — pick a file with fzf, open in $EDITOR via sops
#   secrets api-keys     — fuzzy-match and open directly (skip fzf if one match)
#
# sops decrypts the file, launches $EDITOR, re-encrypts on save.
# Requires: sops, fzf

set -euo pipefail

SECRETS_DIR="${DOTFILES_ROOT:-$HOME/.dotfiles}/secrets"

# Collect all SOPS-managed files (yaml/json/env.enc)
mapfile -t files < <(
	find "$SECRETS_DIR" -maxdepth 1 -type f \( -name "*.yaml" -o -name "*.json" -o -name "*.env.enc" \) \
		! -name "README.md" | sort
)

if [[ ${#files[@]} -eq 0 ]]; then
	echo "No secrets files found in $SECRETS_DIR" >&2
	exit 1
fi

# If an argument was given, try to match it
if [[ -n "${1:-}" ]]; then
	matches=()
	for f in "${files[@]}"; do
		[[ "$(basename "$f")" == *"$1"* ]] && matches+=("$f")
	done
	if [[ ${#matches[@]} -eq 1 ]]; then
		exec sops "${matches[0]}"
	elif [[ ${#matches[@]} -gt 1 ]]; then
		files=("${matches[@]}")
	fi
fi

# fzf picker — show relative paths, preview decrypted content
selected=$(
	printf '%s\n' "${files[@]}" |
		sed "s|$SECRETS_DIR/||" |
		fzf --prompt="secrets> " \
			--preview="sops --decrypt '$SECRETS_DIR/{}' 2>/dev/null || echo '(decrypt failed)'" \
			--preview-window=right:60%
) || exit 0

exec sops "$SECRETS_DIR/$selected"
