#!/usr/bin/env bash
set -euo pipefail

ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
SECRETS_FILE="${ROOT}/secrets/api-keys.yaml"
REMOTE_HOST="${1:-root@ai.hugo.dk}"
REMOTE_ENV="/opt/openclaw/data/.env"
REMOTE_CONFIG="/opt/openclaw/data/openclaw.json"
LOCAL_MODE=0
if [[ "$REMOTE_HOST" == "local" || "$REMOTE_HOST" == "localhost" ]]; then
  LOCAL_MODE=1
fi

tmp_json="$(mktemp)"
remote_json="/tmp/openclaw-sync.json"
trap 'rm -f "$tmp_json"' EXIT

SECRETS_FILE="$SECRETS_FILE" python3 - <<'PY' >"$tmp_json"
import json
import os
import subprocess
import yaml

data = yaml.safe_load(
    subprocess.check_output(
        ["sops", "-d", os.environ["SECRETS_FILE"]],
        text=True,
    )
)

sync = {}

google = data.get("google", {})
if isinstance(google, dict) and google.get("default"):
    sync["GEMINI_API_KEY"] = google["default"]

for section, env_name in [
    ("deepseek", "DEEPSEEK_API_KEY"),
    ("kimi", "KIMI_API_KEY"),
    ("minimax", "MINIMAX_API_KEY"),
    ("openrouter", "OPENROUTER_API_KEY"),
    ("xai", "XAI_API_KEY"),
    ("groq", "GROQ_API_KEY"),
]:
    block = data.get(section, {})
    if isinstance(block, dict) and block.get("api_key"):
        sync[env_name] = block["api_key"]

print(json.dumps(sync))
PY

if [[ "$LOCAL_MODE" -eq 1 ]]; then
  cp "$tmp_json" "$remote_json"
else
  ssh "$REMOTE_HOST" "cat > '$remote_json'" <"$tmp_json"
fi

if [[ "$LOCAL_MODE" -eq 1 ]]; then
  sync_output="$(
    python3 - "$REMOTE_ENV" "$REMOTE_CONFIG" "$remote_json" <<'PY'
import json
import sys
from pathlib import Path

env_path = Path(sys.argv[1])
config_path = Path(sys.argv[2])
sync_path = Path(sys.argv[3])
sync = json.loads(sync_path.read_text())

current = {}
original_env_text = env_path.read_text() if env_path.exists() else ""
if env_path.exists():
    for line in env_path.read_text().splitlines():
        if not line or line.lstrip().startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        current[key] = value

for key, value in sync.items():
    current[key] = value

current.pop("MOONSHOT_API_KEY", None)

backup_path = env_path.with_suffix(env_path.suffix + ".bak.sync")
if env_path.exists():
    backup_path.write_text(env_path.read_text())

ordered_keys = [
    "OPENROUTER_API_KEY",
    "GEMINI_API_KEY",
    "MISTRAL_API_KEY",
    "KIMI_API_KEY",
    "DEEPSEEK_API_KEY",
    "MINIMAX_API_KEY",
    "ZAI_API_KEY",
    "XAI_API_KEY",
    "GROQ_API_KEY",
]
remaining = sorted(k for k in current if k not in ordered_keys)
lines = [f"{key}={current[key]}" for key in ordered_keys if key in current]
lines.extend(f"{key}={current[key]}" for key in remaining)
new_env_text = "\n".join(lines) + "\n"
env_changed = new_env_text != original_env_text
if env_changed:
    env_path.write_text(new_env_text)

original_config_text = config_path.read_text()
config = json.loads(original_config_text)
servers = config.setdefault("mcp", {}).setdefault("servers", {})
minimax = servers.get("minimax-mcp-js")
if isinstance(minimax, dict):
    minimax.setdefault("env", {})["MINIMAX_API_KEY"] = "$MINIMAX_API_KEY"
zai = servers.get("zai-mcp-server")
if isinstance(zai, dict):
    zai.setdefault("env", {})["Z_AI_API_KEY"] = "$ZAI_API_KEY"
new_config_text = json.dumps(config, indent=2) + "\n"
config_changed = new_config_text != original_config_text
if config_changed:
    config_path.write_text(new_config_text)

print(f"Synced {env_path}")
print(f"Updated {config_path}")
print("Backups:")
print(f"- {backup_path}")
print(f"RESTART_REQUIRED={1 if (env_changed or config_changed) else 0}")
sync_path.unlink(missing_ok=True)
PY
  )"
else
  sync_output="$(
    ssh "$REMOTE_HOST" "python3 - '$REMOTE_ENV' '$REMOTE_CONFIG' '$remote_json'" <<'PY'
import json
import sys
from pathlib import Path

env_path = Path(sys.argv[1])
config_path = Path(sys.argv[2])
sync_path = Path(sys.argv[3])
sync = json.loads(sync_path.read_text())

current = {}
original_env_text = env_path.read_text() if env_path.exists() else ""
if env_path.exists():
    for line in env_path.read_text().splitlines():
        if not line or line.lstrip().startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        current[key] = value

for key, value in sync.items():
    current[key] = value

current.pop("MOONSHOT_API_KEY", None)

backup_path = env_path.with_suffix(env_path.suffix + ".bak.sync")
if env_path.exists():
    backup_path.write_text(env_path.read_text())

ordered_keys = [
    "OPENROUTER_API_KEY",
    "GEMINI_API_KEY",
    "MISTRAL_API_KEY",
    "KIMI_API_KEY",
    "DEEPSEEK_API_KEY",
    "MINIMAX_API_KEY",
    "ZAI_API_KEY",
    "XAI_API_KEY",
    "GROQ_API_KEY",
]
remaining = sorted(k for k in current if k not in ordered_keys)
lines = [f"{key}={current[key]}" for key in ordered_keys if key in current]
lines.extend(f"{key}={current[key]}" for key in remaining)
new_env_text = "\n".join(lines) + "\n"
env_changed = new_env_text != original_env_text
if env_changed:
    env_path.write_text(new_env_text)

original_config_text = config_path.read_text()
config = json.loads(original_config_text)
servers = config.setdefault("mcp", {}).setdefault("servers", {})
minimax = servers.get("minimax-mcp-js")
if isinstance(minimax, dict):
    minimax.setdefault("env", {})["MINIMAX_API_KEY"] = "$MINIMAX_API_KEY"
zai = servers.get("zai-mcp-server")
if isinstance(zai, dict):
    zai.setdefault("env", {})["Z_AI_API_KEY"] = "$ZAI_API_KEY"
new_config_text = json.dumps(config, indent=2) + "\n"
config_changed = new_config_text != original_config_text
if config_changed:
    config_path.write_text(new_config_text)

print(f"Synced {env_path}")
print(f"Updated {config_path}")
print("Backups:")
print(f"- {backup_path}")
print(f"RESTART_REQUIRED={1 if (env_changed or config_changed) else 0}")
sync_path.unlink(missing_ok=True)
PY
  )"
fi

printf '%s\n' "$sync_output"

if ! printf '%s\n' "$sync_output" | grep -q '^RESTART_REQUIRED=1$'; then
  echo "No OpenClaw restart needed"
  exit 0
fi

if [[ "$LOCAL_MODE" -eq 1 ]]; then
  cd /opt/openclaw
  docker compose restart openclaw >/dev/null
  sleep 8
  curl -fsS https://ai.hugo.dk/healthz >/dev/null
  python3 - <<'PY'
from pathlib import Path
for line in Path("/opt/openclaw/data/.env").read_text().splitlines():
    if "=" not in line:
        continue
    key = line.split("=", 1)[0]
    print(f"{key}=***")
PY
else
  ssh "$REMOTE_HOST" '
    cd /opt/openclaw
    docker compose restart openclaw >/dev/null
    sleep 8
    curl -fsS https://ai.hugo.dk/healthz >/dev/null
    python3 - <<'"'"'PY'"'"'
from pathlib import Path
for line in Path("/opt/openclaw/data/.env").read_text().splitlines():
    if "=" not in line:
        continue
    key = line.split("=", 1)[0]
    print(f"{key}=***")
PY
'
fi
