#!/usr/bin/env sh
# shell/bash/bashrc — runtime shell hooks that cannot live in Nix
#
# Purpose:
#   Only things that MUST eval in a live shell belong here:
#   - mise runtime activation (needs live eval per shell)
#   - _load_sops_secrets / load-ai-keys (SOPS needs the age key from the
#     running environment, not baked into the Nix closure)
#   - Non-interactive direnv export (programs.direnv uses PROMPT_COMMAND
#     which doesn't fire in non-interactive shells like Claude Code/CI)
#   - Third-party completions not managed by home-manager
#
#   Everything else — PATH, env vars, aliases, prompt, tool hooks (direnv
#   interactive, starship, zoxide) — is declared in home/home.nix and
#   applied by `home-manager switch` (alias: hms).
#
# Sourced by:
#   programs.bash.initExtra  (bash sessions)
#   programs.zsh.initContent (zsh sessions, POSIX-compatible subset)

# Set HOME if missing (safety guard for minimal environments)
[ -z "$HOME" ] && export HOME="/home/mhugo"

# ── Mise (polyglot runtime version manager) ───────────────────────────────────
# Must be activated per-shell so the shims and hooks are wired up.
# Detect zsh vs bash so the right integration is loaded.
if [ -f "$HOME/.local/bin/mise" ]; then
	if [ -n "${ZSH_VERSION:-}" ]; then
		eval "$("$HOME/.local/bin/mise" activate zsh)"
	else
		eval "$("$HOME/.local/bin/mise" activate bash)"
	fi
fi

# ── SOPS on-demand secret loader ─────────────────────────────────────────────
# Decrypts ~/.dotfiles/secrets/api-keys.yaml and exports LLM API credentials.
# Called eagerly below (silent, non-fatal) so keys are available to child
# processes without a manual `load-ai-keys` invocation.
_load_sops_secrets() {
	local secrets_file="$HOME/.dotfiles/secrets/api-keys.yaml"

	if [[ ! -f "$secrets_file" ]]; then
		echo "load-ai-keys: $secrets_file not found" >&2
		return 1
	fi
	if ! command -v sops >/dev/null 2>&1; then
		echo "load-ai-keys: sops not in PATH" >&2
		return 1
	fi

	local decrypted
	decrypted=$(sops --decrypt "$secrets_file" 2>/dev/null) || {
		echo "load-ai-keys: sops decrypt failed (check age key at ${SOPS_AGE_KEY_FILE:-~/.config/sops/age/keys.txt})" >&2
		return 1
	}

	# Helper: extract value under a YAML section (searches up to 5 children)
	_sops_val() { echo "$decrypted" | grep -A5 "^$1:" | grep "$2:" | head -1 | sed "s/.*$2: *//;s/^ *//;s/ *$//" | tr -d '"'; }

	# LLM Gateway (proxies all providers through a single endpoint)
	local val url
	val=$(_sops_val llm_gateway api_key)
	url=$(_sops_val llm_gateway base_url)
	if [ -n "$val" ] && [ -n "$url" ]; then
		export LLM_MUX_API_KEY="$val"
		export LLM_MUX_BASE_URL="$url"
		export ACE_WORKER_API_KEY="$val"
		export GOOGLE_API_KEY="$val"
		export GOOGLE_API_BASE="$url"
		export GEMINI_API_KEY="$val"
		export GEMINI_API_BASE="$url"
	fi

	# OpenAI Gateway (ACE Coder / Goose CLI)
	val=$(_sops_val openai_gateway api_key)
	url=$(_sops_val openai_gateway base_url)
	[ -n "$val" ] && export OPENAI_GATEWAY_API_KEY="$val"
	[ -n "$url" ] && export OPENAI_GATEWAY_BASE_URL="$url"

	# DeepSeek
	val=$(_sops_val deepseek api_key)
	[ -n "$val" ] && export DEEPSEEK_API_KEY="$val"

	# Kimi (Moonshot)
	val=$(_sops_val kimi api_key)
	[ -n "$val" ] && export KIMI_API_KEY="$val"
	val=$(_sops_val kimi code_api_key)
	[ -n "$val" ] && export KIMI_CODE_API_KEY="$val"

	# MiniMax
	val=$(_sops_val minimax api_key)
	[ -n "$val" ] && export MINIMAX_API_KEY="$val"

	# Cloudflare AI Gateway
	val=$(_sops_val cloudflare_ai_gateway aig_token)
	[ -n "$val" ] && export CF_AIG_TOKEN="$val"

	# OpenRouter
	val=$(_sops_val openrouter api_key)
	[ -n "$val" ] && export OPENROUTER_API_KEY="$val"

	# Google free-tier rotation keys
	val=$(echo "$decrypted" | grep -A6 "^google:" | grep "free1:" | sed 's/.*free1: *//;s/ *$//' | tr -d '"')
	[ -n "$val" ] && export GOOGLE_AI_API_KEY_FREE1="$val"
	val=$(echo "$decrypted" | grep -A6 "^google:" | grep "free2:" | sed 's/.*free2: *//;s/ *$//' | tr -d '"')
	[ -n "$val" ] && export GOOGLE_AI_API_KEY_FREE2="$val"
	val=$(echo "$decrypted" | grep -A6 "^google:" | grep "free3:" | sed 's/.*free3: *//;s/ *$//' | tr -d '"')
	[ -n "$val" ] && export GOOGLE_AI_API_KEY_FREE3="$val"
	val=$(echo "$decrypted" | grep -A6 "^google:" | grep "free4:" | sed 's/.*free4: *//;s/ *$//' | tr -d '"')
	[ -n "$val" ] && export GOOGLE_AI_API_KEY_FREE4="$val"

	# Google default key (overrides gateway values with direct key if present)
	val=$(echo "$decrypted" | grep -A1 "^google:" | grep "default:" | sed 's/.*default: *//;s/ *$//' | tr -d '"')
	[ -n "$val" ] && export GOOGLE_API_KEY="$val" && export GEMINI_API_KEY="$val"

	# xAI (Grok)
	val=$(_sops_val xai api_key)
	[ -n "$val" ] && export XAI_API_KEY="$val"

	# Groq
	val=$(_sops_val groq api_key)
	[ -n "$val" ] && export GROQ_API_KEY="$val"

	# Longcat
	val=$(_sops_val longcat api_key)
	[ -n "$val" ] && export LONGCAT_API_KEY="$val"

	# Hetzner
	val=$(_sops_val hetzner api_token)
	[ -n "$val" ] && export HETZNER_API_TOKEN="$val"

	# GOG Galaxy
	val=$(_sops_val gog keyring_password)
	[ -n "$val" ] && export GOG_KEYRING_PASSWORD="$val"

	# Exa (Web Search)
	val=$(_sops_val exa api_key)
	[ -n "$val" ] && export EXA_API_KEY="$val"

	# Ollama Cloud
	val=$(_sops_val ollama_cloud api_key)
	[ -n "$val" ] && export OLLAMA_CLOUD_API_KEY="$val"

	# LLM Gateway bearer token (aichat / direct API clients)
	val=$(_sops_val llm_gateway bearer_key)
	[ -n "$val" ] && export LLM_GATEWAY_BEARER_KEY="$val"

	unset -f _sops_val
}

alias load-ai-keys='_load_sops_secrets'

# ── Non-interactive direnv export ────────────────────────────────────────────
# programs.direnv sets up PROMPT_COMMAND hooks, which only fire in interactive
# shells. Non-interactive shells (Claude Code, Cursor, CI) must call
# `direnv export` explicitly to inherit the project environment.
# DIRENV_DIFF/DIRENV_WATCHES are unset first so direnv re-exports everything
# (parent may have set them; .bashrc reset PATH so they'd be stale).
if command -v direnv >/dev/null 2>&1 && [[ $- != *i* ]]; then
	unset DIRENV_DIFF DIRENV_WATCHES
	eval "$(direnv export bash 2>/dev/null)"
fi

# ── Third-party completions ───────────────────────────────────────────────────
# OpenClaw CLI completions — generated by `openclaw completion bash`.
# Installed to npm-global prefix by home-manager activation; falls back to
# ~/.openclaw/completions for legacy installs.
_oc_comp="$HOME/.npm-global/lib/node_modules/openclaw/completions/openclaw.bash"
if [ -f "$_oc_comp" ]; then
	source "$_oc_comp"
elif [ -f "$HOME/.openclaw/completions/openclaw.bash" ]; then
	source "$HOME/.openclaw/completions/openclaw.bash"
fi
unset _oc_comp

# ── Homebrew (Linux Homebrew, present on some machines) ───────────────────────
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
	eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
fi
