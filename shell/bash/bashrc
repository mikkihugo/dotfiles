#!/usr/bin/env sh
# shell/bash/bashrc — runtime shell hooks that cannot live in Nix
#
# Purpose:
#   Only things that MUST eval in a live shell belong here:
#   - mise runtime activation (needs live eval per shell)
#   - _load_sops_secrets / load-ai-keys (SOPS needs the age key from the
#     running environment, not baked into the Nix closure)
#   - Non-interactive direnv export (programs.direnv uses PROMPT_COMMAND
#     which doesn't fire in non-interactive shells like Claude Code/CI)
#   - Runtime-only shell integration not managed by home-manager
#
#   Everything else — PATH, env vars, aliases, prompt, tool hooks (direnv
#   interactive, starship, zoxide) — is declared in home/home.nix and
#   applied by `home-manager switch` (alias: hms).
#
# Sourced by:
#   programs.bash.initExtra  (bash sessions)
#   programs.zsh.initContent (zsh sessions, POSIX-compatible subset)

# Set HOME if missing (safety guard for minimal environments)
[ -z "$HOME" ] && export HOME="/home/mhugo"

# ── Mise (polyglot runtime version manager) ───────────────────────────────────
# Must be activated per-shell so the shims and hooks are wired up.
# Detect zsh vs bash so the right integration is loaded.
mise_bin="$(command -v mise 2>/dev/null || true)"
if [ -n "$mise_bin" ]; then
	if [ -n "${ZSH_VERSION:-}" ]; then
		eval "$("$mise_bin" activate zsh)"
	else
		eval "$("$mise_bin" activate bash)"
	fi

	_mise_node_bin="$("$mise_bin" which node 2>/dev/null || true)"
	if [ -n "$_mise_node_bin" ]; then
		export PATH="$(dirname "$_mise_node_bin"):$PATH"
	fi
	unset _mise_node_bin

	# mise activate prepends tool install dirs ahead of home.sessionPath, which
	# shadows HM wrappers in ~/.local/bin (goose → llm-gateway, kimi, …).
	export PATH="$HOME/.local/bin:$PATH"
fi
unset mise_bin

# ── SOPS on-demand secret loader ─────────────────────────────────────────────
# Decrypts ~/.dotfiles/secrets/api-keys.yaml and exports LLM API credentials.
# Called eagerly below (silent, non-fatal) so keys are available to child
# processes without a manual `load-ai-keys` invocation.
_load_sops_secrets() {
	local secrets_file="$HOME/.dotfiles/secrets/api-keys.yaml"

	if [[ ! -f "$secrets_file" ]]; then
		echo "load-ai-keys: $secrets_file not found" >&2
		return 1
	fi
	if ! command -v sops >/dev/null 2>&1; then
		echo "load-ai-keys: sops not in PATH" >&2
		return 1
	fi

	local decrypted
	decrypted=$(sops --decrypt "$secrets_file" 2>/dev/null) || {
		echo "load-ai-keys: sops decrypt failed (check age key at ${SOPS_AGE_KEY_FILE:-~/.config/sops/age/keys.txt})" >&2
		return 1
	}

	# Helper: extract value under a YAML section (searches up to 5 children)
	_sops_val() { echo "$decrypted" | grep -A5 "^$1:" | grep "$2:" | head -1 | sed "s/.*$2: *//;s/^ *//;s/ *$//" | tr -d '"'; }
	_sops_sf_val() { echo "$decrypted" | grep -A80 "^sf:" | grep "$1:" | head -1 | sed "s/.*$1: *//;s/^ *//;s/ *$//" | tr -d '"'; }

	# LLM Gateway (proxies all providers through a single endpoint)
	local val url
	val=$(_sops_val llm_gateway api_key)
	url=$(_sops_val llm_gateway base_url)
	if [ -n "$val" ] && [ -n "$url" ]; then
		export LLM_MUX_API_KEY="$val"
		export LLM_MUX_BASE_URL="$url"
		export ACE_WORKER_API_KEY="$val"
	fi

	# OpenAI Gateway (ACE Coder / Goose CLI)
	val=$(_sops_val openai_gateway api_key)
	url=$(_sops_val openai_gateway base_url)
	[ -n "$val" ] && export OPENAI_GATEWAY_API_KEY="$val"
	[ -n "$url" ] && export OPENAI_GATEWAY_BASE_URL="$url"

	# DeepSeek
	val=$(_sops_val deepseek api_key)
	[ -n "$val" ] && export DEEPSEEK_API_KEY="$val"

	# Kimi (Moonshot)
	val=$(_sops_val kimi api_key)
	[ -n "$val" ] && export KIMI_API_KEY="$val"
	val=$(_sops_val kimi code_api_key)
	[ -n "$val" ] && export KIMI_CODE_API_KEY="$val"

	# MiniMax
	val=$(_sops_val minimax api_key)
	[ -n "$val" ] && export MINIMAX_API_KEY="$val"

	# Cloudflare AI Gateway
	val=$(_sops_val cloudflare_ai_gateway aig_token)
	[ -n "$val" ] && export CF_AIG_TOKEN="$val"

	# OpenRouter
	val=$(_sops_val openrouter api_key)
	[ -n "$val" ] && export OPENROUTER_API_KEY="$val"

	# xAI (Grok)
	val=$(_sops_val xai api_key)
	[ -n "$val" ] && export XAI_API_KEY="$val"

	# Groq
	val=$(_sops_val groq api_key)
	[ -n "$val" ] && export GROQ_API_KEY="$val"

	# Longcat
	val=$(_sops_val longcat api_key)
	[ -n "$val" ] && export LONGCAT_API_KEY="$val"

	# ElevenLabs
	val=$(_sops_val elevenlabs api_key)
	[ -n "$val" ] && export ELEVENLABS_API_KEY="$val"
	val=$(_sops_val elevenlabs voice_id)
	[ -n "$val" ] && export ELEVENLABS_VOICE_ID="$val"

	# Hetzner
	val=$(_sops_val hetzner api_token)
	[ -n "$val" ] && export HETZNER_API_TOKEN="$val"

	# Cloudflare (Global API Key — flarectl + ad-hoc CF API; X-Auth-Email + X-Auth-Key)
	val=$(_sops_val cloudflare api_token)
	if [ -n "$val" ]; then
		export CF_API_KEY="$val"
		export CF_API_EMAIL="$(_sops_val cloudflare email)"
		# Aliases some tools (Terraform CF provider, others) expect
		export CLOUDFLARE_API_KEY="$CF_API_KEY"
		export CLOUDFLARE_API_EMAIL="$CF_API_EMAIL"
	fi

	# gog Google Workspace CLI encrypted file keyring
	val=$(_sops_val gog keyring_password)
	[ -n "$val" ] && export GOG_KEYRING_PASSWORD="$val"

	# Exa (Web Search)
	val=$(_sops_val exa api_key)
	[ -n "$val" ] && export EXA_API_KEY="$val"

	# Tavily (Web Search — stored under sf section)
	val=$(_sops_sf_val TAVILY_API_KEY)
	[ -n "$val" ] && export TAVILY_API_KEY="$val"

	# Ollama Cloud
	val=$(_sops_val ollama_cloud api_key)
	[ -n "$val" ] && export OLLAMA_CLOUD_API_KEY="$val"

	# SF provider keys stored under the sf section
	val=$(_sops_sf_val MISTRAL_API_KEY)
	[ -n "$val" ] && export MISTRAL_API_KEY="$val"
	val=$(_sops_sf_val ZAI_API_KEY)
	[ -n "$val" ] && export ZAI_API_KEY="$val"
	val=$(_sops_sf_val XIAOMI_API_KEY)
	[ -n "$val" ] && export XIAOMI_API_KEY="$val"
	val=$(_sops_sf_val ALIBABA_API_KEY)
	[ -n "$val" ] && export ALIBABA_API_KEY="$val"
	val=$(_sops_sf_val ALIBABA_CODING_PLAN_API_KEY)
	[ -n "$val" ] && export ALIBABA_CODING_PLAN_API_KEY="$val"
	val=$(_sops_sf_val ALIBABA_TOKEN_PLAN_API_KEY)
	[ -n "$val" ] && export ALIBABA_TOKEN_PLAN_API_KEY="$val"
	val=$(_sops_sf_val GOOGLE_GENERATIVE_AI_API_KEY)
	if [ -n "$val" ]; then
		export GOOGLE_GENERATIVE_AI_API_KEY="$val" # opencode google provider (AI Studio, free Flash tier)
		export GEMINI_API_KEY="$val"
	fi
	val=$(_sops_sf_val OPENCODE_API_KEY)
	[ -n "$val" ] && export OPENCODE_API_KEY="$val"
	val=$(_sops_sf_val OPENCODE_GO_API_KEY)
	[ -n "$val" ] && export OPENCODE_GO_API_KEY="$val"
	val=$(_sops_sf_val OLLAMA_API_KEY)
	if [ -n "$val" ]; then
		export OLLAMA_API_KEY="$val"
		export OLLAMA_CLOUD_API_KEY="$val"
	fi

	# LLM Gateway bearer token (aichat / direct API clients)
	val=$(_sops_val llm_gateway bearer_key)
	[ -n "$val" ] && export LLM_GATEWAY_BEARER_KEY="$val"

	# FlakeCache WebDAV action token (sccache remote backend). Same host as the
	# Nix substituter in config/nix/local-build.nix.conf — one fleet cache URL.
	# Endpoint + multilevel chain only when the token loaded; otherwise clear
	# inherited Home Manager / parent-shell WebDAV state so sccache can start
	# on local disk instead of 401ing `.sccache_check`.
	val=$(_sops_val flakecache sccache_action_token)
	if [ -n "$val" ]; then
		export SCCACHE_WEBDAV_TOKEN="$val"
		export SCCACHE_WEBDAV_ENDPOINT="https://cache.flakecache.com/default/sccache/project/singularity-engine"
		export SCCACHE_MULTILEVEL_CHAIN="disk,webdav"
		export SCCACHE_MULTILEVEL_WRITE_ERROR_POLICY="l0"
	else
		unset SCCACHE_WEBDAV_TOKEN SCCACHE_WEBDAV_ENDPOINT
		unset SCCACHE_WEBDAV_USERNAME SCCACHE_WEBDAV_PASSWORD
		unset SCCACHE_MULTILEVEL_CHAIN SCCACHE_MULTILEVEL_WRITE_ERROR_POLICY
	fi

	unset -f _sops_val _sops_sf_val
}

alias load-ai-keys='_load_sops_secrets'

# claude-squad harness shortcuts
# default (claude) — same as plain `claude-squad`
alias cs='claude-squad'
# opencode + MiniMax coding plan (flat-rate sub, direct minimax-coding-plan provider)
alias cs-minimax='claude-squad -p "opencode -m minimax/MiniMax-M3"'
# opencode default model
alias cs-opencode='claude-squad -p opencode'
# codex
alias cs-codex='claude-squad -p "/home/mhugo/.local/share/mise/installs/codex/latest/codex"'
# opencode + Qwen3.7 Max (bailian-token-plan, flat-rate)
alias cs-qwen='claude-squad -p "opencode -m bailian-token-plan/qwen3.7-max"'
# opencode + Xiaomi MiMo v2.5 Pro
alias cs-mimo='claude-squad -p "opencode -m xiaomi/mimo-v2.5-pro"'

# Kubernetes context helpers. kubectx/kubens read KUBECONFIG, which Home
# Manager sets to ~/.kube/config.
kctxf() {
	local selected
	selected="$(kubectx | fzf --height=40% --reverse --prompt='kubectx> ')" || return
	[ -n "$selected" ] && kubectx "$selected"
}

knsf() {
	local selected
	selected="$(kubens | fzf --height=40% --reverse --prompt='kubens> ')" || return
	[ -n "$selected" ] && kubens "$selected"
}

# Eager load — makes keys available to child processes (Claude Code, Cursor, CI)
# without requiring a manual `load-ai-keys` invocation.
_load_sops_secrets 2>/dev/null || true

# ── Non-interactive direnv export ────────────────────────────────────────────
# programs.direnv sets up PROMPT_COMMAND hooks, which only fire in interactive
# shells. Non-interactive shells (Claude Code, Cursor, CI) must call
# `direnv export` explicitly to inherit the project environment.
# DIRENV_DIFF/DIRENV_WATCHES are unset first so direnv re-exports everything
# (parent may have set them; .bashrc reset PATH so they'd be stale).
if command -v direnv >/dev/null 2>&1 && [[ $- != *i* ]]; then
	unset DIRENV_DIFF DIRENV_WATCHES
	eval "$(direnv export bash 2>/dev/null)"
fi

# ── Homebrew (Linux Homebrew, present on some machines) ───────────────────────
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
	eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
fi
